DASHSCOPE_API_KEY=your_dashscope_api_key_here
TEXT_MODEL=qwen-plus
JUDGE_MODEL=qwen-max
IMAGE_MODEL=qwen-image
IMAGE_EDIT_MODEL=qwen-image-edit-max
IMAGE_SIZE=1024x1024
OUTPUT_DIR=outputs
MAX_RETRIES=3
REQUEST_TIMEOUT=120
DISABLE_ENV_PROXY=true
DASHSCOPE_BASE_HTTP_API_URL=https://dashscope.aliyuncs.com/api/v1
IMAGE_WATERMARK=false
IMAGE_PROMPT_EXTEND=true
IMAGE_NEGATIVE_PROMPT=低分辨率，低画质，肢体畸形，手指畸形，画面过饱和，蜡像感，人脸无细节，过度光滑，画面具有AI感，构图混乱，文字模糊，扭曲。
